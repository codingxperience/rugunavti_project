{
  "name": "ruguna-vocational-training-institute",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src prisma scripts --ext .ts,.tsx --cache --cache-location .eslintcache",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:validate": "prisma validate",
    "storage:setup": "tsx scripts/setup-supabase-storage.ts",
    "prod:check": "tsx scripts/verify-production-env.ts",
    "deploy:check": "npm run prod:check && npm run db:validate && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@clerk/nextjs": "6.39.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.8.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "next": "^16.2.3",
    "posthog-js": "^1.258.1",
    "posthog-node": "^5.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.62.0",
    "resend": "^4.6.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.36.0",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.6",
    "prisma": "^6.8.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vercel": "^50.44.0"
  }
}
