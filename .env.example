NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL / Supabase Postgres
# Use Supabase database connection strings with sslmode=require.
# Production should use the Supabase pooled connection for DATABASE_URL and direct connection for DIRECT_URL.
DATABASE_URL=
DIRECT_URL=

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/elearning/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/elearning/register
CLERK_SIGN_IN_URL=/elearning/login
CLERK_SIGN_UP_URL=/elearning/register

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_PUBLIC=ruguna-public
SUPABASE_BUCKET_PRIVATE=ruguna-private

# Transactional email
RESEND_API_KEY=
RESEND_FROM_EMAIL=Ruguna Institute <noreply@ruguna.ac.ug>

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Platform flags
RUGUNA_USE_DATABASE=true
RUGUNA_ALLOW_DEV_AUTH=false
RUGUNA_ENABLE_ANALYTICS=false

# Production role bootstrap. Add comma-separated trusted emails so staff can reach
# their dashboards before managing roles from Clerk/admin tooling.
RUGUNA_SUPER_ADMIN_EMAILS=
RUGUNA_REGISTRAR_ADMIN_EMAILS=
RUGUNA_FINANCE_ADMIN_EMAILS=
RUGUNA_INSTRUCTOR_EMAILS=
